# Copia este archivo como .env.public y rellena los valores
# Solo se usa para modo de URL fija con ngrok

NGROK_AUTHTOKEN=pega_aqui_tu_token_ngrok
NGROK_DOMAIN=tu-dominio-o-subdominio.ngrok.app
PUBLIC_SITE_URL=

# Opcional
PORT=8080
HOST=0.0.0.0

# Modo de uso:
# - Local: no hace falta cambiar nada
# - Dinamico: necesita NGROK_AUTHTOKEN
# - Fijo: necesita NGROK_AUTHTOKEN, NGROK_DOMAIN y PUBLIC_SITE_URL
